{
    "name": "zuugle-api",
    "version": "3.0.0",
    "description": "",
    "main": "index.js",
    "engines": {
        "node": "^20.19.6",
        "npm": ">=9.5"
    },
    "bugs": {
        "url": "https://github.com/bahnzumberg/zuugle-api/issues/",
        "email": "test@zuugle.at"
    },
    "scripts": {
        "start": "tsx watch src/index.js",
        "build": "npm run build:compile && npm run build:copy && npm run build:patch",
        "build:compile": "tsc -p tsconfig.build.json",
        "build:copy": "cp database.sql docker-compose.yaml docker-compose.uat.yaml restore_databases.sh package.json package-lock.json ./build/ && cp -r src/utils/gpx/error-images build/utils/gpx/ && cp -r src/utils/country-geojson build/utils/ && cp -r public build/",
        "build:patch": "sed -i 's|node build/|node |g' ./build/package.json",
        "test": "jest",
        "reset-database": "node build/jobs/resetDatabase.js",
        "rebuild-docker": "node build/jobs/rebuildDocker.js",
        "import-data-docker-download": "node build/jobs/syncDataDockerDownload.js",
        "import-data-prod": "node build/jobs/syncDataProd.js",
        "import-files": "node build/jobs/syncFiles.js",
        "refresh-search-suggestions": "node build/jobs/refreshSearchSuggestions.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky || true",
        "lint-staged": "lint-staged",
        "lint": "eslint --cache",
        "lint:fix": "eslint --cache --fix",
        "tsc": "tsc --noEmit"
    },
    "lint-staged": {
        "**/*.js": "eslint --cache --fix --max-warnings 0",
        "**/*": "prettier --write --ignore-unknown"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.2",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^16.4.0",
        "pixelmatch": "^7.2.0",
        "prettier": "^3.8.4",
        "ts-jest": "^29.4.0",
        "tsx": "^4.20.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "cross-spawn": "^7.0.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "fs-extra": "^11.3.5",
        "ioredis": "^5.11.1",
        "knex": "^3.2.10",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.2",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.5",
        "pg": "^8.21.0",
        "puppeteer": "^24.43.1",
        "request": "^2.88.2",
        "sharp": "^0.34.5",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "watch": "^1.0.2",
        "xml-js": "^1.6.11",
        "xmlbuilder2": "^4.0.3"
    },
    "volta": {
        "node": "20.19.6"
    }
}
