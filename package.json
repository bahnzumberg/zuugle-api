{
    "name": "zuugle-api",
    "version": "3.0.0",
    "description": "",
    "main": "index.js",
    "engines": {
        "node": "^20.19.6",
        "npm": ">=9.5"
    },
    "bugs": {
        "url": "https://github.com/bahnzumberg/zuugle-api/issues/",
        "email": "test@zuugle.at"
    },
    "scripts": {
        "start": "nodemon --watch ./src --exec ts-node -- src/index.js",
        "build": "npm run build:compile && npm run build:copy && npm run build:patch",
        "build:compile": "babel src -d build --extensions .js,.ts",
        "build:copy": "cp database.sql docker-compose.yaml docker-compose.uat.yaml restore_databases.sh package.json package-lock.json ./build/ && cp -r src/utils/gpx/error-images build/utils/gpx/ && cp -r src/utils/country-geojson build/utils/ && cp -r public build/",
        "build:patch": "sed -i 's|node build/|node |g' ./build/package.json",
        "test": "jest",
        "import-data": "node build/jobs/syncDataProd.js",
        "import-data-full": "node build/jobs/syncDataProd.js",
        "reset-database": "node build/jobs/resetDatabase.js",
        "rebuild-docker": "node build/jobs/rebuildDocker.js",
        "import-data-docker-download": "node build/jobs/syncDataDockerDownload.js",
        "import-data-prod": "node build/jobs/syncDataProd.js",
        "import-files": "node build/jobs/syncFiles.js",
        "import-files-prod": "node build/jobs/syncFiles.js",
        "refresh-search-suggestions": "node build/jobs/refreshSearchSuggestions.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky || true",
        "lint-staged": "lint-staged",
        "lint": "eslint --cache",
        "lint:fix": "eslint --cache --fix",
        "tsc": "tsc --noEmit"
    },
    "lint-staged": {
        "**/*.js": "eslint --cache --fix --max-warnings 0",
        "**/*": "prettier --write --ignore-unknown"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.29.3",
        "@babel/preset-typescript": "^7.28.5",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "babel-jest": "^30.3.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "dependencies": {
        "@babel/runtime": "^7.29.2",
        "cors": "^2.8.6",
        "cross-spawn": "^7.0.6",
        "express": "^5.2.1",
        "fs-extra": "^11.3.4",
        "ioredis": "^5.10.1",
        "knex": "^3.2.9",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.2",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.3",
        "pg": "^8.20.0",
        "puppeteer": "^24.42.0",
        "request": "^2.88.2",
        "sharp": "^0.34.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "watch": "^1.0.2",
        "xml-js": "^1.6.11",
        "xmlbuilder2": "^4.0.3"
    },
    "volta": {
        "node": "20.19.6"
    }
}
