# Copy to .env and fill in your values. .env is gitignored — never commit real secrets.
# On servers these come from the process env (PM2 env block / systemd EnvironmentFile).
#
# NODE_ENV selects which config key is used (production|development); both keys read the
# same variables below, so a host's env alone determines which database it talks to.
NODE_ENV=development

# --- Main search database (PostgreSQL, knexfile.js) ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=
DB_NAME=zuugle_suchseite_dev
# Docker container name, used by the rebuild/restore jobs. Leave empty on native (PROD) hosts.
DB_CONTAINER_NAME=zuugle-container
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Tour source database (MySQL, knexfileTourenDb.js, read-only) ---
TOUREN_DB_HOST=
TOUREN_DB_USER=
TOUREN_DB_PASSWORD=
TOUREN_DB_NAME=tourendatenbank
